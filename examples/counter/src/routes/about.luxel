<template>
  <h1>{message}</h1>
  <p>{blurb}</p>
</template>

<script>
export async function load(ctx) {
  const data = {
    message: "About Luxel",
    blurb: "Static about page for multi-route prototype.",
  };
  ctx.store.set("route:about:view", data, { tags: ["about"] });
  return data;
}
</script>

<style scoped>
p {
  margin: 0;
}
</style>
