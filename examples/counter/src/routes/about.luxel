<template>
  <h1>{message}</h1>
  <p>{blurb}</p>
</template>

<script>
export const prerender = true;

export async function load(ctx) {
  ctx.store.set("route:about:message", { message: "About Luxel" }, { tags: ["about"] });
  ctx.store.set(
    "route:about:blurb",
    { blurb: "Static about page for multi-route prototype." },
    { tags: ["about"] },
  );
}
</script>

<style scoped>
p {
  margin: 0;
}
</style>
