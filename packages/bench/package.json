{
  "name": "@luxel/bench",
  "version": "0.0.0",
  "type": "module",
  "dependencies": {
    "@luxel/luxel": "workspace:*"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@solidjs/start": "^1.1.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "fastify": "^5.3.3",
    "next": "^15.3.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "solid-js": "^1.9.7",
    "svelte": "^5.33.0",
    "vite": "^6.3.5",
    "vite-plugin-solid": "^2.11.6",
    "vue": "^3.5.16",
    "vue-vapor": "npm:vue@3.6.0-beta.14"
  },
  "scripts": {
    "bench": "bun run src/run.ts",
    "bench:winrk": "bun run src/winrk-run.ts",
    "bench:winrk:serve": "bun run src/winrk/serve-stack.ts",
    "bench:winrk:merge": "bun run src/winrk-merge.ts",
    "bench:winrk:repro-all": "bun run src/winrk-repro-all.ts",
    "bench:cleanup-orphans": "bun run src/winrk/bench-cleanup-orphans-cli.ts",
    "bench:competitors:build": "bun run bench:cleanup-orphans && bun run --cwd competitors build",
    "bench:winrk:full": "bun run bench:competitors:build && bun run bench:ensure-core-node && bun run bench:winrk",
    "bench:repro": "bun run bench:competitors:build && bun run bench:ensure-core-node && bun run bench:winrk:repro-all",
    "bench:ensure-core-node": "bun -e \"import { ensureCoreNodeBuilt } from '@luxel/luxel/bench'; await ensureCoreNodeBuilt();\""
  }
}
